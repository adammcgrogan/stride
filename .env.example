STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Dev: http://localhost:8080/auth/callback
# Production: https://your-railway-domain.up.railway.app/auth/callback
STRAVA_REDIRECT_URL=http://localhost:8080/auth/callback

ADDR=:8080

# Local dev: leave as default (SQLite file in working directory)
# Railway: set to /data/stride.db and mount a volume at /data
DB_PATH=stride.db

# Leave empty for local dev (cookies are plain integers, no Secure flag)
# Production: set to a long random string — enables HMAC-signed cookies + Secure flag
# Generate one with: openssl rand -hex 32
SESSION_SECRET=
